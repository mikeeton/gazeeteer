# Server
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Public tile rendering key. MapTiler keys are used in browser tile URLs, but keep
# the source value managed through the backend config endpoint.
MAPTILER_KEY=your_maptiler_key_here

# GeoNames username used by server-side proxy routes.
GEONAMES_USER=your_geonames_username_here

# WeatherAPI key used only by the backend.
WEATHER_API_KEY=your_weatherapi_key_here
